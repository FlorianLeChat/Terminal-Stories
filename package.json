{
    "name": "terminal-stories",
    "type": "module",
    "author": "Florian Trayon (https://github.com/FlorianLeChat)",
    "license": "MIT",
    "private": true,
    "version": "1.0.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/FlorianLeChat/Terminal-Stories.git"
    },
    "bugs": {
        "url": "https://github.com/FlorianLeChat/Terminal-Stories/issues"
    },
    "devDependencies": {
        "vite": "~8.0",
        "husky": "~9.1",
        "eslint": "~10.2",
        "svelte": "~5.55",
        "cspell": "~9.8",
        "globals": "~16.5",
        "prettier": "~3.8",
        "typescript": "~6.0",
        "@eslint/js": "~10.0",
        "tailwindcss": "~4.2",
        "lint-staged": "~16.4",
        "svelte-check": "~4.4",
        "@sveltejs/kit": "~2.57",
        "@commitlint/cli": "~20.5",
        "@tsconfig/svelte": "~5.0",
        "@playwright/test": "~1.61",
        "@tailwindcss/vite": "~4.2",
        "typescript-eslint": "~8.59",
        "@cspell/dict-fr-fr": "~2.3",
        "@inlang/paraglide-js": "~2.18",
        "eslint-plugin-svelte": "~3.17",
        "prettier-plugin-svelte": "~3.5",
        "eslint-formatter-gitlab": "~7.1",
        "@stylistic/eslint-plugin": "~5.10",
        "@sveltejs/adapter-static": "~3.0",
        "@commitlint/config-conventional": "~20.5"
    },
    "engines": {
        "node": ">=22.0",
        "npm": ">=10.5"
    },
    "scripts": {
        "dev": "vite",
        "test": "playwright test",
        "lint": "eslint . --format gitlab --ext .js,.ts,.svelte",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "build": "vite build",
        "format": "prettier --write \"**/*.{js,ts,svelte}\"",
        "preview": "vite preview",
        "prepare": "husky && svelte-kit sync || echo ''",
        "commitlint": "commitlint --edit",
        "lint-staged": "lint-staged",
        "check-spell": "cspell src/lib/data/** --show-context --show-suggestions"
    },
    "browserslist": [
        "defaults"
    ]
}
